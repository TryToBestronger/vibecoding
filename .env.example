DEEPSEEK_API_KEY=your_deepseek_api_key_here
PORT=3000

# AI 置信度阈值（85=精炼筛选，75=平衡，60=宽松）
AI_CONFIDENCE_THRESHOLD=85

# RSSHub 实例地址（推荐自建 Docker: docker run -d -p 1200:1200 rsshub/rsshub）
RSSHUB_BASE_URL=http://localhost:1200
# 兼容旧变量名
# RSSHUB_BASE=http://localhost:1200
# 公共实例（不稳定，仅测试）:
# RSSHUB_BASE_URL=https://rsshub.app

# ── 各平台搜索质量阈值（仅对关键词搜索生效，热榜/热搜不受影响）──────────────
# 配合 48h 时间过滤使用，阈值宜偏低以保留新发布内容
# 微博：满足任意一项即通过（点赞 OR 转发 OR 评论）
WEIBO_MIN_LIKES=10
WEIBO_MIN_REPOSTS=5
WEIBO_MIN_COMMENTS=3
# 知乎：满足任意一项即通过（赞同 OR 评论）
ZHIHU_MIN_VOTEUP=10
ZHIHU_MIN_COMMENT=3
# B站：满足任意一项即通过（播放量 OR 收藏）
BILIBILI_MIN_VIEWS=100
BILIBILI_MIN_FAVORITES=5
# Hacker News：满足任意一项即通过（投票 OR 评论）
HN_MIN_SCORE=100
HN_MIN_COMMENTS=30
# ────────────────────────────────────────────────────────────────────────────

# 平台 Cookie（浏览器登录后从开发者工具 Network 复制，用于关键词搜索）
# 微博 Cookie，有效期约 30 天
WEIBO_COOKIE=
# 知乎 Cookie，有效期约 7-30 天
ZHIHU_COOKIE=
# B站 Cookie（可选，浏览器登录后复制 buvid3 等字段，可降低 412 风控概率）
BILIBILI_COOKIE=

# Twitter/X API Key（从 https://twitterapi.io 获取，可选）
TWITTER_API_KEY=your_twitter_api_key_here
# Twitter 互动过滤阈值（四项须同时达标，白名单账号阈值为 30%）
TWITTER_MIN_LIKES=200
TWITTER_MIN_RETWEETS=50
TWITTER_MIN_REPLIES=25
TWITTER_MIN_VIEWS=5000

# 时间窗口过滤（超过此时长（小时）的内容将被丢弃）
MAX_CONTENT_AGE_HOURS=48

# 每轮检查各来源的配额上限（条数）
QUOTA_WEIBO=5
QUOTA_ZHIHU=5
QUOTA_BILIBILI=3
QUOTA_TWITTER=5
QUOTA_RSSHUB=5
# 单轮所有来源合并后的总条数上限
QUOTA_TOTAL_PER_CYCLE=20
